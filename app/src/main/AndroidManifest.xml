<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Required to post notifications on Android 13+ -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Required for foreground service (alert processing) -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />

    <!-- Declare packages the app may query/launch (Android 11+ package visibility) -->
    <queries>
        <package android:name="com.google.android.projection.gearhead" />
        <intent>
            <action android:name="android.intent.action.VIEW" />
            <data android:scheme="market" />
        </intent>
    </queries>

    <application
        android:name=".RedAutoAlertApp"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.Material3.DayNight"
        tools:targetApi="34">

        <!-- Declares Android Auto notification support to the car host -->
        <meta-data
            android:name="com.google.android.gms.car.application"
            android:resource="@xml/automotive_app_desc" />

        <!-- Main settings activity -->
        <activity
            android:name=".ui.SettingsActivity"
            android:exported="true"
            android:label="@string/app_name">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Notification Listener Service: captures Red Alert notifications -->
        <service
            android:name=".service.AlertNotificationListener"
            android:exported="true"
            android:permission="android.permission.BIND_NOTIFICATION_LISTENER_SERVICE">
            <intent-filter>
                <action android:name="android.service.notification.NotificationListenerService" />
            </intent-filter>
        </service>

        <!-- Handles mark-as-read and reply actions from Android Auto messaging notifications -->
        <receiver
            android:name=".service.AlertDismissReceiver"
            android:enabled="true"
            android:exported="false">
            <intent-filter>
                <action android:name="com.redautoalert.ACTION_MARK_READ" />
                <action android:name="com.redautoalert.ACTION_REPLY" />
            </intent-filter>
        </receiver>

    </application>

</manifest>
